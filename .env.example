# Linux Resource Monitor Configuration

# WebSocket server port (default: 9002)
RESOURCE_MONITOR_PORT=9002

# Update interval in milliseconds (default: 1000)
RESOURCE_MONITOR_UPDATE_INTERVAL_MS=1000

# Number of top processes to report (default: 25)
RESOURCE_MONITOR_TOP_PROCESSES_COUNT=25

# Log level: TRACE, DEBUG, INFO, WARN, ERROR, CRITICAL (default: INFO)
RESOURCE_MONITOR_LOG_LEVEL=INFO

# Log file path (default: logs/resource-monitor.log)
RESOURCE_MONITOR_LOG_FILE=logs/resource-monitor.log

# Enable console output (default: true)
RESOURCE_MONITOR_LOG_TO_CONSOLE=true

# Enable file output (default: true)
RESOURCE_MONITOR_LOG_TO_FILE=true
